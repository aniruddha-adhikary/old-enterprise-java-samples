{
  "name": "bigcorp-trade-order-management",
  "version": "2.0.0",
  "description": "Modern rewrite of the BigCorp Trade Order Management System",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node src/api/server.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "4.18.2",
    "amqplib": "0.10.3",
    "nodemailer": "6.9.7",
    "node-cron": "3.0.3",
    "uuid": "9.0.0",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/amqplib": "0.10.4",
    "@types/nodemailer": "6.4.14",
    "@types/node-cron": "3.0.11",
    "@types/uuid": "9.0.7",
    "@types/node": "20.10.0",
    "@types/jest": "29.5.11",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "testMatch": ["**/*.test.ts"]
  }
}
