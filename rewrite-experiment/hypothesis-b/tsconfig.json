{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@domain/*": ["src/domain/*"],
      "@rules/*": ["src/rules/*"],
      "@settlement/*": ["src/settlement/*"],
      "@pricing/*": ["src/pricing/*"],
      "@notifications/*": ["src/notifications/*"],
      "@risk/*": ["src/risk/*"],
      "@derivatives/*": ["src/derivatives/*"],
      "@audit/*": ["src/audit/*"],
      "@regulatory/*": ["src/regulatory/*"],
      "@integration/*": ["src/integration/*"],
      "@api/*": ["src/api/*"],
      "@config/*": ["src/config/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
