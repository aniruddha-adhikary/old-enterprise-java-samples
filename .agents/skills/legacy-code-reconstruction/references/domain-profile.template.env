# domain-profile.env — per-project domain profile for legacy-code-reconstruction.
#
# The skill ADAPTS to whatever the project is. After running 00-calibrate, read its DOMAIN
# NOUNS / DOMAIN VERBS / CANDIDATE CRITICAL OPERATIONS, name the domain, and fill this in.
# Copy to <repo>/joern-workspace/domain-profile.env (next to the CPG) — run-all.sh sources it to
# tune scripts 13–16, and generate-companion-skill.sh reads it to emit a project-specific skill.
#
# Nothing here is finance-specific. Examples by domain:
#   trading:    COMPUTE_VERBS="calculate,price,commission,convert,settle"
#   healthcare: COMPUTE_VERBS="dose,score,assess,eligibility,calculate"
#   logistics:  COMPUTE_VERBS="route,rate,schedule,allocate,estimate"
#   insurance:  COMPUTE_VERBS="rate,underwrite,score,reserve,calculate"

DOMAIN_SLUG="my-domain"                         # kebab-case id used to name the companion skill
DOMAIN_LABEL="<one-line description of the system's domain>"
ROOT_PACKAGE=""                                 # from 00-calibrate ROOT PACKAGE (optional; auto-derived if blank)

CORE_ENTITIES=""                                # comma list: the value-objects the spec centers on
COMPUTE_VERBS=""                                # comma list: this domain's computation/decision verbs -> scripts 13,16
STAKES_VERBS=""                                 # comma list: high-stakes effect verbs (reject/approve/charge/dispatch...) -> script 14
CRITICAL_MODULES=""                             # comma list: package/module hints to focus failure analysis -> script 15
DOMAIN_KEYWORDS=""                              # comma list: trigger words for the generated companion skill's description
